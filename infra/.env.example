# silva-omnium 자체호스팅 환경변수
# 실제 .env 는 install-mac-mini.sh 가 생성한다 (gitignore).
# 수동 작성 시 이 템플릿을 복사 후 값 채우기.

# 호스트의 silva-omnium 절대 경로 (bind mount 용)
SILVA_REPO=/Users/peterseo/peterica/silva-omnium

# code-server 비밀번호 (24자 무작위 권장)
SILVA_CODE_SERVER_PASSWORD=CHANGE_ME

# (선택) Ollama 모델 — 기본 gemma4:latest
# 8GB RAM 환경에선 더 작은 모델 권장:
#   exaone3.5:7.8b (4.8GB), kanana-2.1b (1.5GB)
# OLLAMA_MODEL=exaone3.5:7.8b
